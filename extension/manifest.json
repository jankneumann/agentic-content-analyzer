{
  "manifest_version": 3,
  "name": "Newsletter Aggregator - Save URL",
  "description": "Save any webpage to your Newsletter Aggregator for content extraction and processing.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Newsletter Aggregator"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
