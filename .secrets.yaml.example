# Secrets Template for Profile-Based Configuration
# =================================================
# Copy this file to .secrets.yaml and fill in your actual values.
# IMPORTANT: .secrets.yaml is gitignored and should NEVER be committed!
#
# These secrets are referenced by profiles using ${VARIABLE_NAME} syntax.
# Environment variables always take precedence over values defined here.
#
# See docs/PROFILES.md for more information.

# =============================================================================
# LLM API Keys
# =============================================================================
# Required: At least one LLM provider key
ANTHROPIC_API_KEY: sk-ant-xxx
OPENAI_API_KEY: sk-xxx
GOOGLE_API_KEY: xxx
XAI_API_KEY: xai-xxx
PERPLEXITY_API_KEY: pplx-xxx

# =============================================================================
# Database Credentials
# =============================================================================

# Supabase Cloud (when using DATABASE_PROVIDER=supabase)
SUPABASE_DB_PASSWORD: your-supabase-password

# Neon Serverless (when using DATABASE_PROVIDER=neon)
NEON_DATABASE_URL: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname
NEON_API_KEY: neon-api-key-for-branching

# Railway (when using DATABASE_PROVIDER=railway)
# Note: Railway auto-injects RAILWAY_DATABASE_URL in deployment
RAILWAY_DATABASE_URL: postgresql://user:password@host:port/db

# =============================================================================
# Neo4j / Knowledge Graph
# =============================================================================

# Local Neo4j (default) — referenced as ${NEO4J_PASSWORD} in profiles
NEO4J_PASSWORD: your-local-neo4j-password

# Neo4j AuraDB (when using NEO4J_PROVIDER=auradb)
NEO4J_AURADB_URI: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_AURADB_PASSWORD: your-auradb-password

# =============================================================================
# Storage Credentials
# =============================================================================

# AWS S3 (when using STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID: AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY: your-aws-secret-key

# Supabase Storage (when using STORAGE_PROVIDER=supabase)
SUPABASE_ACCESS_KEY_ID: your-supabase-s3-access-key
SUPABASE_SECRET_ACCESS_KEY: your-supabase-s3-secret-key

# Railway MinIO (when using STORAGE_PROVIDER=railway)
# Note: Railway auto-injects these in deployment
MINIO_ROOT_USER: minio-user
MINIO_ROOT_PASSWORD: minio-password

# =============================================================================
# Observability
# =============================================================================

# Braintrust (when using OBSERVABILITY_PROVIDER=braintrust)
BRAINTRUST_API_KEY: your-braintrust-api-key

# Opik / Comet Cloud (when using OBSERVABILITY_PROVIDER=opik)
OPIK_API_KEY: your-comet-api-key

# Langfuse (when using OBSERVABILITY_PROVIDER=langfuse)
LANGFUSE_PUBLIC_KEY: pk-lf-xxx
LANGFUSE_SECRET_KEY: sk-lf-xxx

# =============================================================================
# External Services
# =============================================================================

# Email delivery
SENDGRID_API_KEY: SG.xxx

# Text-to-speech
ELEVENLABS_API_KEY: sk_xxx

# Web search
TAVILY_API_KEY: tvly-xxx

# Search provider API keys (for embedding/reranking)
VOYAGE_API_KEY: pa-xxx
COHERE_API_KEY: xxx
JINA_API_KEY: jina-xxx

# =============================================================================
# Application Security
# =============================================================================

# Admin endpoints protection
ADMIN_API_KEY: your-admin-api-key

# Owner authentication (login password + JWT signing seed)
APP_SECRET_KEY: your-app-secret-key

# Substack Session Cookie (substack.sid)
SUBSTACK_SESSION_COOKIE: your-substack-sid-cookie
