# Frontend Environment Configuration
# Copy to .env and adjust values for your setup.

# API URL for production builds (not needed for local dev — Vite proxy handles it)
# VITE_API_URL=https://your-api.example.com

# Frontend OpenTelemetry Tracing
# Set to "true" to enable browser-side trace propagation, Web Vitals,
# and Error Boundary OTel integration. Requires backend OTel to be enabled.
VITE_OTEL_ENABLED=false

# Opik project name for frontend traces (should match backend's opik_project_name)
# VITE_OPIK_PROJECT_NAME=newsletter-aggregator
