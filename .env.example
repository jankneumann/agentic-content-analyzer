# Environment
ENVIRONMENT=development  # development or production

# Database Configuration
DATABASE_URL=postgresql://newsletter_user:newsletter_password@localhost:5432/newsletters
REDIS_URL=redis://localhost:6379/0

# Test Database Configuration (for integration tests)
TEST_DATABASE_URL=postgresql://newsletter_user:newsletter_password@localhost:5432/newsletters_test
TEST_NEO4J_URI=bolt://localhost:7688  # Dedicated test Neo4j instance (different port)
TEST_NEO4J_USER=neo4j
TEST_NEO4J_PASSWORD=newsletter_password

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=newsletter_password

# Graphiti Configuration
SEMAPHORE_LIMIT=1  # Controls concurrency for LLM API calls (1-2 for free tier, 5-8 for paid)

# Agent Framework API Keys
ANTHROPIC_API_KEY=sk-ant-xxx  # Required for Claude SDK (summarization + entity extraction)
OPENAI_API_KEY=sk-xxx          # Required for Graphiti embeddings (semantic search)
GOOGLE_API_KEY=xxx             # Optional - for framework comparison

# Gmail API Configuration
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Substack RSS Configuration
# Option 1: Comma-separated list of feed URLs
RSS_FEEDS=

# Option 2: File with feed URLs (one per line)
RSS_FEEDS_FILE=rss_feeds.txt

# Email Delivery (for production)
SENDGRID_API_KEY=xxx

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Digest Schedule
DAILY_DIGEST_HOUR=7    # 7am
WEEKLY_DIGEST_DAY=1    # Monday (0=Sunday, 1=Monday, etc.)
WEEKLY_DIGEST_HOUR=7   # 7am

# Token Budget Configuration (optional - for hierarchical digest creation)
# These control when to automatically create hierarchical digests
DIGEST_CONTEXT_WINDOW_PERCENTAGE=0.5    # Use 50% of context window for input (remaining for output)
DIGEST_NEWSLETTER_BUDGET_PERCENTAGE=0.6  # Allocate 60% of input budget to newsletter summaries
DIGEST_THEME_BUDGET_PERCENTAGE=0.3       # Allocate 30% of input budget to theme context
DIGEST_PROMPT_OVERHEAD_PERCENTAGE=0.1    # Allocate 10% of input budget to prompt instructions

# Document Parser Configuration
ENABLE_DOCLING=true                     # Enable Docling parser for advanced PDF/OCR
DOCLING_ENABLE_OCR=false                # Enable OCR for scanned documents (requires pip install docling[ocr])
DOCLING_MAX_FILE_SIZE_MB=100            # Maximum file size for Docling processing
DOCLING_TIMEOUT_SECONDS=300             # Processing timeout for large documents
DOCLING_CACHE_DIR=/tmp/docling          # Cache directory for Docling models

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50                   # Maximum file upload size
