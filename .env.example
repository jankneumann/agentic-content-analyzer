# Environment
ENVIRONMENT=development  # development or production

# =============================================================================
# Database Configuration
# =============================================================================
# DATABASE_PROVIDER determines which database backend to use.
# Valid values: local, supabase, neon
DATABASE_PROVIDER=local

# Primary connection URL (used by all providers as fallback)
DATABASE_URL=postgresql://newsletter_user:newsletter_password@localhost:5432/newsletters

# Optional: Provider-specific URLs override DATABASE_URL when set
# LOCAL_DATABASE_URL=...   # Override for local provider
# NEON_DATABASE_URL=...    # Override for neon provider

# Redis for caching and job queues
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Supabase Cloud Database (when DATABASE_PROVIDER=supabase)
# -----------------------------------------------------------------------------
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_DB_PASSWORD=your-db-password
# SUPABASE_REGION=us-east-1
# SUPABASE_AZ=0
# SUPABASE_POOLER_MODE=transaction
# SUPABASE_DIRECT_URL=  # Optional: explicit direct URL for migrations

# -----------------------------------------------------------------------------
# Neon Serverless PostgreSQL (when DATABASE_PROVIDER=neon)
# -----------------------------------------------------------------------------
# Set DATABASE_URL to your Neon URL, or use NEON_DATABASE_URL for explicit override
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname
# NEON_DATABASE_URL=...  # Optional: explicit Neon URL (overrides DATABASE_URL)
# NEON_API_KEY=neon-api-key  # For branch management
# NEON_PROJECT_ID=project-id  # For branch management
# NEON_DIRECT_URL=  # Optional: explicit direct URL for migrations

# Test Database Configuration (for integration tests)
TEST_DATABASE_URL=postgresql://newsletter_user:newsletter_password@localhost:5432/newsletters_test
TEST_NEO4J_URI=bolt://localhost:7688  # Dedicated test Neo4j instance (different port)
TEST_NEO4J_USER=neo4j
TEST_NEO4J_PASSWORD=newsletter_password

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=newsletter_password

# Graphiti Configuration
SEMAPHORE_LIMIT=1  # Controls concurrency for LLM API calls (1-2 for free tier, 5-8 for paid)

# Agent Framework API Keys
ANTHROPIC_API_KEY=sk-ant-xxx  # Required for Claude SDK (summarization + entity extraction)
OPENAI_API_KEY=sk-xxx          # Required for Graphiti embeddings (semantic search)
GOOGLE_API_KEY=xxx             # Optional - for framework comparison

# Gmail API Configuration
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Substack RSS Configuration
# Option 1: Comma-separated list of feed URLs
RSS_FEEDS=

# Option 2: File with feed URLs (one per line)
RSS_FEEDS_FILE=rss_feeds.txt

# ElevenLabs API Key (for voice generation)
ELEVENLABS_API_KEY=sk_xxx

# Email Delivery (for production)
SENDGRID_API_KEY=xxx

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Digest Schedule
DAILY_DIGEST_HOUR=7    # 7am
WEEKLY_DIGEST_DAY=1    # Monday (0=Sunday, 1=Monday, etc.)
WEEKLY_DIGEST_HOUR=7   # 7am

# Token Budget Configuration (optional - for hierarchical digest creation)
# These control when to automatically create hierarchical digests
DIGEST_CONTEXT_WINDOW_PERCENTAGE=0.5    # Use 50% of context window for input (remaining for output)
DIGEST_NEWSLETTER_BUDGET_PERCENTAGE=0.6  # Allocate 60% of input budget to newsletter summaries
DIGEST_THEME_BUDGET_PERCENTAGE=0.3       # Allocate 30% of input budget to theme context
DIGEST_PROMPT_OVERHEAD_PERCENTAGE=0.1    # Allocate 10% of input budget to prompt instructions

# =============================================================================
# Observability / Telemetry Configuration
# =============================================================================
# OBSERVABILITY_PROVIDER selects the LLM observability backend.
# Valid values: noop (default), opik, braintrust, otel
OBSERVABILITY_PROVIDER=noop

# OpenTelemetry infrastructure (auto-instrumentation for FastAPI, SQLAlchemy, httpx)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=newsletter-aggregator
# OTEL_EXPORTER_OTLP_ENDPOINT=         # OTLP HTTP endpoint (e.g., http://localhost:4318)
# OTEL_EXPORTER_OTLP_HEADERS=          # Comma-separated key=value pairs
# OTEL_LOG_PROMPTS=false                # Log prompt/completion text (PII risk)

# OTel Log Bridge (requires OTEL_ENABLED=true)
# OTEL_LOGS_ENABLED=true                # Enable log bridge to OTLP (default: true)
# OTEL_LOGS_EXPORT_LEVEL=WARNING        # Min level for OTLP export (DEBUG, INFO, WARNING, ERROR)
# LOG_FORMAT=json                        # Console output format: "json" (default) or "text"

# -----------------------------------------------------------------------------
# Opik Provider (when OBSERVABILITY_PROVIDER=opik)
# -----------------------------------------------------------------------------
# Self-hosted (docker-compose.opik.yml):
#   No OTEL_EXPORTER_OTLP_ENDPOINT needed — defaults to http://localhost:5173/api/v1/private/otel
#   Start with: docker compose -f docker-compose.opik.yml -p opik up -d
#   Opik UI: http://localhost:5173
#
# Comet Cloud:
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://www.comet.com/opik/api/v1/private/otel
#   OPIK_API_KEY=<your-comet-api-key>
#
# OPIK_API_KEY=                         # Comet Cloud API key (optional for self-hosted)
# OPIK_WORKSPACE=                       # Comet Cloud workspace
# OPIK_PROJECT_NAME=newsletter-aggregator

# -----------------------------------------------------------------------------
# Braintrust Provider (when OBSERVABILITY_PROVIDER=braintrust)
# -----------------------------------------------------------------------------
# BRAINTRUST_API_KEY=                   # Required for Braintrust
# BRAINTRUST_PROJECT_NAME=newsletter-aggregator
# BRAINTRUST_API_URL=https://api.braintrust.dev

# Health check configuration
HEALTH_CHECK_TIMEOUT_SECONDS=5

# Document Parser Configuration
ENABLE_DOCLING=true                     # Enable Docling parser for advanced PDF/OCR
DOCLING_ENABLE_OCR=false                # Enable OCR for scanned documents (requires pip install docling[ocr])
DOCLING_MAX_FILE_SIZE_MB=100            # Maximum file size for Docling processing
DOCLING_TIMEOUT_SECONDS=300             # Processing timeout for large documents
DOCLING_CACHE_DIR=/tmp/docling          # Cache directory for Docling models

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50                   # Maximum file upload size

# =============================================================================
# Image Storage Configuration
# =============================================================================
# IMAGE_STORAGE_PROVIDER determines where extracted images are stored.
# Valid values: local, s3, supabase
IMAGE_STORAGE_PROVIDER=local

# Local Storage (default - good for development)
IMAGE_STORAGE_PATH=data/images          # Directory for local image storage

# Common Settings
IMAGE_MAX_SIZE_MB=10                    # Maximum image file size
ENABLE_IMAGE_EXTRACTION=true            # Enable extraction from HTML/PDF
ENABLE_YOUTUBE_KEYFRAMES=false          # Enable YouTube keyframe extraction

# -----------------------------------------------------------------------------
# S3 Storage (when IMAGE_STORAGE_PROVIDER=s3)
# -----------------------------------------------------------------------------
# IMAGE_STORAGE_BUCKET=newsletter-images
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=                    # Optional - uses boto3 defaults if not set
# AWS_SECRET_ACCESS_KEY=                # Optional - uses boto3 defaults if not set
# S3_ENDPOINT_URL=                      # Optional - for S3-compatible services (MinIO, etc.)

# -----------------------------------------------------------------------------
# Supabase Storage (when IMAGE_STORAGE_PROVIDER=supabase)
# -----------------------------------------------------------------------------
# Requires: SUPABASE_PROJECT_REF from database config section
# SUPABASE_STORAGE_BUCKET=images        # Bucket name in Supabase Storage
# SUPABASE_SERVICE_ROLE_KEY=eyJ...      # Service role key from Supabase Dashboard
# SUPABASE_ACCESS_KEY_ID=xxx
# SUPABASE_SECRET_ACCESS_KEY=xxx
# SUPABASE_STORAGE_PUBLIC=false         # Whether bucket allows public access
