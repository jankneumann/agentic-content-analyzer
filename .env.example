# =============================================================================
# Newsletter Aggregator — Non-Secret Configuration
# =============================================================================
#
# RECOMMENDED: Use profile-based configuration instead of this file:
#
#   export PROFILE=local           # Activates profiles/local.yaml
#   aca profile list               # See available profiles
#   aca profile show local         # View profile contents
#
# When PROFILE is set, profiles + .secrets.yaml handle everything.
# This .env file is only needed as a FALLBACK when not using profiles.
#
# SECRETS (API keys, passwords) belong in .secrets.yaml, NOT here.
# See .secrets.yaml.example for the template.
#
# See docs/PROFILES.md for complete documentation.
# =============================================================================

# Environment
ENVIRONMENT=development  # development, staging, or production

# =============================================================================
# Provider Choices
# =============================================================================
# These select which infrastructure backends to use.
# With profiles active, set these in the profile YAML instead.

DATABASE_PROVIDER=local            # local, supabase, neon, railway
# NEO4J_PROVIDER=local             # local, auradb
# STORAGE_PROVIDER=local           # local, s3, supabase, railway
OBSERVABILITY_PROVIDER=noop        # noop, opik, braintrust, langfuse, otel

# =============================================================================
# Database Configuration
# =============================================================================

# Primary connection URL (used by local provider)
DATABASE_URL=postgresql://newsletter_user:newsletter_password@localhost:5432/newsletters

# Optional: Provider-specific URLs override DATABASE_URL when set
# LOCAL_DATABASE_URL=...             # Override for local provider
# NEON_DATABASE_URL=...              # Override for neon provider (set in .secrets.yaml)
# NEON_PROJECT_ID=...                # For Neon branch management
# SUPABASE_PROJECT_REF=...           # For Supabase cloud
# SUPABASE_REGION=us-east-1          # Supabase region
# SUPABASE_POOLER_MODE=transaction   # Supabase pooler mode

# Test Database Configuration (for integration tests)
TEST_DATABASE_URL=postgresql://newsletter_user:newsletter_password@localhost:5432/newsletters_test
TEST_NEO4J_URI=bolt://localhost:7688
TEST_NEO4J_USER=neo4j
TEST_NEO4J_PASSWORD=newsletter_password

# =============================================================================
# Neo4j Configuration
# =============================================================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=newsletter_password

# Graphiti Configuration
SEMAPHORE_LIMIT=1  # Controls concurrency for LLM API calls

# =============================================================================
# Gmail & RSS Configuration
# =============================================================================

GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
RSS_FEEDS=
RSS_FEEDS_FILE=rss_feeds.txt

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_FORMAT=json  # json (default) or text

# =============================================================================
# Observability / Telemetry Configuration
# =============================================================================

# OpenTelemetry infrastructure (auto-instrumentation for FastAPI, SQLAlchemy, httpx)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=newsletter-aggregator
# OTEL_EXPORTER_OTLP_ENDPOINT=         # OTLP HTTP endpoint
# OTEL_EXPORTER_OTLP_HEADERS=          # Comma-separated key=value pairs
# OTEL_LOG_PROMPTS=false                # Log prompt/completion text (PII risk)

# OTel Log Bridge (requires OTEL_ENABLED=true)
# OTEL_LOGS_ENABLED=true                # Enable log bridge to OTLP
# OTEL_LOGS_EXPORT_LEVEL=WARNING        # Min level for OTLP export

# =============================================================================
# Search & Embedding Configuration
# =============================================================================

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# BM25 strategy: auto (detect pg_search), paradedb, native
SEARCH_BM25_STRATEGY=auto

# Reranking (optional, disabled by default)
# SEARCH_RERANK_ENABLED=false
# SEARCH_RERANK_PROVIDER=cohere
# SEARCH_RERANK_MODEL=
# SEARCH_RERANK_TOP_K=50

# Chunking defaults
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# Search weights and parameters
# SEARCH_BM25_WEIGHT=0.5
# SEARCH_VECTOR_WEIGHT=0.5
# SEARCH_RRF_K=60
# SEARCH_DEFAULT_LIMIT=20
# SEARCH_MAX_LIMIT=100

# Feature flag for search indexing at ingestion time
ENABLE_SEARCH_INDEXING=true

# =============================================================================
# Document Parser Configuration
# =============================================================================

ENABLE_DOCLING=true
DOCLING_ENABLE_OCR=false
DOCLING_MAX_FILE_SIZE_MB=100
DOCLING_TIMEOUT_SECONDS=300
DOCLING_CACHE_DIR=/tmp/docling

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50

# =============================================================================
# Image Storage Configuration
# =============================================================================

IMAGE_STORAGE_PROVIDER=local
IMAGE_STORAGE_PATH=data/images
IMAGE_MAX_SIZE_MB=10
ENABLE_IMAGE_EXTRACTION=true
ENABLE_YOUTUBE_KEYFRAMES=false

# S3 Storage (when IMAGE_STORAGE_PROVIDER=s3)
# IMAGE_STORAGE_BUCKET=newsletter-images
# AWS_REGION=us-east-1
# S3_ENDPOINT_URL=                      # For S3-compatible services (MinIO)

# Supabase Storage (when IMAGE_STORAGE_PROVIDER=supabase)
# SUPABASE_STORAGE_BUCKET=images
# SUPABASE_STORAGE_PUBLIC=false

# =============================================================================
# Digest Schedule
# =============================================================================

DAILY_DIGEST_HOUR=7
WEEKLY_DIGEST_DAY=1    # Monday (0=Sunday, 1=Monday, etc.)
WEEKLY_DIGEST_HOUR=7

# Token Budget Configuration (for hierarchical digest creation)
DIGEST_CONTEXT_WINDOW_PERCENTAGE=0.5
DIGEST_NEWSLETTER_BUDGET_PERCENTAGE=0.6
DIGEST_THEME_BUDGET_PERCENTAGE=0.3
DIGEST_PROMPT_OVERHEAD_PERCENTAGE=0.1

# =============================================================================
# Health Check
# =============================================================================

HEALTH_CHECK_TIMEOUT_SECONDS=5
